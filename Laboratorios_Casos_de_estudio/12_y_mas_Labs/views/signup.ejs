<%- include('includes/_header') %>
<form action="/users/signup" method="POST">
    <div class="field">
        <label for="name" class="label">Name</label>
        <div class="control">
            <input id="name" name="name" class="input" type="text" placeholder="e.g John Doe" required>
        </div>
    </div>

    <div class="field">
        <label for="email" class="label">Email</label>
        <div class="control">
            <input id="email" name="email" class="email" type="text" placeholder="e.g johndoe@gmail.com" required>
        </div>
    </div>

    <div class="field">
        <label for="username" class="label">Username</label>
        <div class="control">
            <input id="username" name="username" class="input" type="text" placeholder="e.g Vi" required>
        </div>
    </div>

    <div class="field">
        <label for="password" class="label">Password</label>
        <div class="control">
            <input id="password" name="password" class="input" type="password">
        </div>
    </div>

    <input class="button is-primary" type="submit" value="Guardar">
</form>
<%- include('includes/_footer') %>